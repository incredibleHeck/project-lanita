// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  role         UserRole @default(STUDENT)
  isActive     Boolean  @default(true)
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile Profile?

  // Relations for Student domain
  studentRecord StudentRecord?  @relation("UserToStudent")
  children      StudentRecord[] @relation("ParentToStudent")
  
  // Relation for Teacher domain
  teacherAllocations SubjectAllocation[]
}

model Profile {
  id            String   @id @default(uuid()) @db.Uuid
  firstName     String
  lastName      String
  middleName    String?
  dob           DateTime
  gender        Gender
  contactNumber String
  address       Json
  avatarUrl     String?

  user   User   @relation(fields: [userId], references: [id])
  userId String @unique @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Class {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  code      String    @unique
  sections  Section[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Section {
  id          String              @id @default(uuid()) @db.Uuid
  name        String
  capacity    Int
  class       Class               @relation(fields: [classId], references: [id])
  classId     String              @db.Uuid
  students    StudentRecord[]
  allocations SubjectAllocation[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model Subject {
  id          String              @id @default(uuid()) @db.Uuid
  name        String
  code        String              @unique
  description String?
  isElective  Boolean             @default(false)
  allocations SubjectAllocation[]
  results     Result[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model SubjectAllocation {
  id             String           @id @default(uuid()) @db.Uuid
  section        Section          @relation(fields: [sectionId], references: [id])
  sectionId      String           @db.Uuid
  subject        Subject          @relation(fields: [subjectId], references: [id])
  subjectId      String           @db.Uuid
  teacher        User             @relation(fields: [teacherId], references: [id])
  teacherId      String           @db.Uuid
  academicYear   AcademicYear     @relation(fields: [academicYearId], references: [id])
  academicYearId String           @db.Uuid
  attendance     AttendanceRecord[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([sectionId, subjectId, academicYearId])
}

model StudentRecord {
  id              String   @id @default(uuid()) @db.Uuid
  admissionNumber String   @unique
  enrollmentDate  DateTime

  user   User   @relation("UserToStudent", fields: [userId], references: [id])
  userId String @unique @db.Uuid

  currentSection   Section @relation(fields: [currentSectionId], references: [id])
  currentSectionId String  @db.Uuid

  parent   User?   @relation("ParentToStudent", fields: [parentId], references: [id])
  parentId String? @db.Uuid

  attendance AttendanceRecord[]
  results    Result[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AttendanceRecord {
  id      String           @id @default(uuid()) @db.Uuid
  date    DateTime
  status  AttendanceStatus
  remarks String?

  student   StudentRecord @relation(fields: [studentId], references: [id])
  studentId String        @db.Uuid

  allocation   SubjectAllocation @relation(fields: [allocationId], references: [id])
  allocationId String            @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, allocationId, date])
  @@index([studentId, date])
}

model AcademicYear {
  id          String              @id @default(uuid()) @db.Uuid
  name        String              @unique
  startDate   DateTime
  endDate     DateTime
  isCurrent   Boolean             @default(false)
  allocations SubjectAllocation[]
  exams       Exam[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model Exam {
  id             String        @id @default(uuid()) @db.Uuid
  name           String
  startDate      DateTime
  endDate        DateTime
  maxScore       Int           @default(100)
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id])
  academicYearId String        @db.Uuid
  results        Result[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Result {
  id        String        @id @default(uuid()) @db.Uuid
  score     Float
  grade     String?
  remarks   String?
  student   StudentRecord @relation(fields: [studentId], references: [id])
  studentId String        @db.Uuid
  exam      Exam          @relation(fields: [examId], references: [id])
  examId    String        @db.Uuid
  subject   Subject       @relation(fields: [subjectId], references: [id])
  subjectId String        @db.Uuid
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([studentId, examId, subjectId])
}
