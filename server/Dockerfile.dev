FROM node:20-alpine

WORKDIR /app

# Copy package files first for better layer caching
COPY package.json package-lock.json* ./

# Install all dependencies (including devDependencies for hot reload)
RUN npm install

# Copy prisma schema and config for generate
COPY prisma ./prisma
COPY prisma.config.ts ./

# Dummy DATABASE_URL for prisma generate (required at build time)
ENV DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dummy"

# Generate Prisma client
RUN npx prisma generate

# Copy rest of source (will be overwritten by volume mount in dev)
COPY . .

EXPOSE 3000

# Install deps, generate Prisma, run migrations, then start dev server with watch mode
# npm install runs on start to sync with mounted source; Prisma generate needed after mount
CMD ["sh", "-c", "npm install && npx prisma generate && npx prisma migrate deploy && npm run start:dev"]
