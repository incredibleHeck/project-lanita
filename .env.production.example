# ===========================================
# Project Lanita - Production Environment
# ===========================================
# Copy to .env on your VPS before deployment
# cp .env.production.example .env

# ----- Database -----
POSTGRES_PASSWORD=your-secure-database-password
DB_PORT=5433

# ----- Backend API -----
PORT=3000
API_PORT=4001
JWT_ACCESS_SECRET=your-production-jwt-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-production-jwt-refresh-secret-min-32-chars
CORS_ORIGIN=https://lanita.com,https://www.lanita.com
NODE_ENV=production
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# ----- Frontend (must match Nginx config) -----
WEB_PORT=4000
API_URL=https://lanita.com/api

# ----- ML Service -----
ML_SERVICE_URL=http://ml-service:5000
