# ===========================================
# Project Lanita - Environment Configuration
# ===========================================
# Copy this file to .env and customize values

# ----- Database -----
POSTGRES_PASSWORD=postgres
DB_PORT=5433

# ----- Backend API -----
API_PORT=4001
JWT_ACCESS_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
NODE_ENV=development
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# ----- Frontend -----
WEB_PORT=4000
API_URL=http://localhost:4001

# ----- ML Service (for timetable generation) -----
ML_SERVICE_URL=http://localhost:5000

# ===========================================
# PRODUCTION EXAMPLE (uncomment and modify):
# ===========================================
# POSTGRES_PASSWORD=super-secure-password-123
# DB_PORT=5432
# API_PORT=3000
# JWT_SECRET=your-production-jwt-secret-min-32-chars
# JWT_REFRESH_SECRET=your-production-refresh-secret
# NODE_ENV=production
# WEB_PORT=80
# API_URL=http://your-server-ip-or-domain:3000
