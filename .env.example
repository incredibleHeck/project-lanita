# ===========================================
# Project Lanita - Environment Configuration
# ===========================================
# Copy this file to .env and customize values

# ----- Database -----
# For local dev with PostgreSQL: replace CHANGE_ME with your DB password from setup
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/lanita_db
POSTGRES_PASSWORD=postgres
DB_PORT=5433

# ----- Backend API -----
API_PORT=4001
# REQUIRED: Server will not start without these. Use strong random values in production (e.g. 32+ chars).
# Never use defaults in production. Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
CORS_ORIGIN=http://localhost:3000,http://localhost:3002,http://127.0.0.1:3000,http://127.0.0.1:3002
NODE_ENV=development
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# ----- Frontend -----
WEB_PORT=3000
API_URL=http://localhost:4001

# ----- ML Service (for timetable generation) -----
ML_SERVICE_URL=http://localhost:5000

# ===========================================
# PRODUCTION EXAMPLE (see .env.production.example):
# ===========================================
# For production/VPS deployment, copy .env.production.example to .env
# and set JWT_ACCESS_SECRET, JWT_REFRESH_SECRET, API_URL, CORS_ORIGIN, etc.
