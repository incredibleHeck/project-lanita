# ===========================================
# Docker Local Development - Copy to .env
# ===========================================
# cp .env.docker.example .env

POSTGRES_PASSWORD=postgres
DB_PORT=5433
API_PORT=4001
WEB_PORT=3000

# JWT secrets (must match server auth config)
JWT_ACCESS_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

# CORS - allow browser from client URL (must include WEB_PORT)
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# API URL - from browser to server (host ports)
API_URL=http://localhost:4001

NODE_ENV=development

# ML Service (for timetable generation - use ml-service hostname in Docker)
ML_SERVICE_URL=http://ml-service:5000

# ===========================================
# PRODUCTION OVERRIDE (when deploying to VPS with Nginx):
# ===========================================
# WEB_PORT=4000
# API_URL=https://lanita.com/api
# CORS_ORIGIN=https://lanita.com,https://www.lanita.com
# NODE_ENV=production
# JWT_ACCESS_SECRET=(your-production-secret)
# JWT_REFRESH_SECRET=(your-production-secret)
# See .env.production.example for full template
